<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Powered-By "Penhora.app.br"

  # HTML e demais arquivos: nunca servir do cache sem revalidar no servidor.
  # Garante que todo deploy chegue imediatamente a todos os usuários.
  # Apache responde 304 (sem corpo) quando o arquivo não mudou — eficiente.
  Header set Cache-Control "no-cache"

  # Assets com hash de conteúdo (/assets/*): cache de 1 ano, imutável.
  # Seguro porque o Vite embute o hash do conteúdo no nome do arquivo;
  # qualquer alteração gera um nome diferente, invalidando o cache naturalmente.
  <If "%{REQUEST_URI} =~ m#^/assets/.*$#">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </If>
</IfModule>
