<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Powered-By "Penhora.app.br"

  # HTML: nunca armazenar em cache, em nenhuma camada.
  # Cobre: browser, Apache, Cloudflare Edge, LiteSpeed e outros proxies.
  Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  Header set Pragma "no-cache"
  Header set Expires "0"
  Header set CDN-Cache-Control "no-store"
  Header set Cloudflare-CDN-Cache-Control "no-store"
  Header set Surrogate-Control "no-store"

  # Assets com hash de conteúdo (/assets/*): cache de 1 ano, imutável.
  # Seguro porque o Vite embute o hash do conteúdo no nome do arquivo;
  # qualquer alteração gera um nome diferente, invalidando o cache naturalmente.
  <If "%{REQUEST_URI} =~ m#^/assets/.*$#">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header unset CDN-Cache-Control
    Header unset Cloudflare-CDN-Cache-Control
    Header unset Surrogate-Control
  </If>
</IfModule>

# Desabilita cache do LiteSpeed (usado na Hostinger) para todas as respostas HTML
<IfModule LiteSpeed>
  CacheLookup off
</IfModule>
